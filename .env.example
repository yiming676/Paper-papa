POSTGRES_DB=study_assistant
POSTGRES_USER=study_user
POSTGRES_PASSWORD=study_password
DATABASE_URL=postgresql+psycopg://study_user:study_password@db:5432/study_assistant

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_CHAT_COMPLETIONS_PATH=/chat/completions
MODEL_NAME=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=24000
LLM_MAX_INPUT_CHARS=160000
LLM_FULL_TEXT_PAGE_LIMIT=30
LLM_JSON_MODE=true
ALLOW_LLM_FALLBACK=false
ENABLE_RESEARCH_SEARCH=false
SEMANTIC_SCHOLAR_API_KEY=
MAX_EXPAND_DEPTH=10
MAX_KEYWORD_DEPTH=10
MAX_PREREQUISITES_PER_CONCEPT=5
MAX_ANNOTATION_ENTITIES=30

BACKEND_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
